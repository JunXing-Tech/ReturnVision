# ============================================
# 退运智录 线上部署环境变量模板
# 使用方式：
#   1. cp .env.example .env
#   2. 填入真实密钥
#   3. chmod 600 .env
#   4. 执行 deploy.sh
# ============================================

# ---------- MySQL 数据库（宿主机系统级安装） ----------
# 数据库用户名（对应 application.yml 的 ${MYSQL_USER}）
MYSQL_USER=return_ocr
# 数据库密码
MYSQL_PASSWORD=your_password_here

# ---------- 智谱 OCR 引擎A ----------
ZHIPU_API_KEY=your_zhipu_api_key

# ---------- 阿里云 OCR 引擎B ----------
ALIYUN_AK_ID=your_aliyun_access_key_id
ALIYUN_AK_SECRET=your_aliyun_access_key_secret

# ---------- 腾讯云 COS ----------
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket-name

# ---------- DeepSeek LLM ----------
DEEPSEEK_API_KEY=your_deepseek_api_key

# ---------- 飞书 ----------
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_APP_TOKEN=your_feishu_app_token
FEISHU_TABLE_ID=tblxxxxxxxxxxxx
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ---------- 域名 & HTTPS ----------
# Let's Encrypt 证书申请邮箱（用于证书到期提醒，必填）
CERTBOT_EMAIL=your_email@example.com
# 是否使用 Let's Encrypt Staging 环境签发测试证书
# 开发/测试阶段设为 true 避免触发生产限流
# 正式上线前必须设为 false
LETSENCRYPT_STAGING=false
